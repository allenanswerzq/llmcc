multiple-functions
===============================================================================

lang: go

--- file: main.go ---
package main

import "fmt"

func Add(a, b int) int {
    return a + b
}

func Main() {
    result := Add(1, 2)
    fmt.Println(result)
}

--- expect:block-graph ---
(root:1  (000_main)
  (func:2 Add)
  (func:3 Main
    (@fdep:2 Add)
  )
)
