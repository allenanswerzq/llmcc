===============================================================================
struct-and-methods
===============================================================================

lang: go

--- file: main.go ---
package main

type User struct {
    Name  string
    Email string
}

func (u *User) Display() string {
    return u.Name + " <" + u.Email + ">"
}

func NewUser(name, email string) *User {
    return &User{Name: name, Email: email}
}

--- expect:block-graph ---
(root:1  (000_main)
  (class:2 User)
  (func:3 NewUser)
)




