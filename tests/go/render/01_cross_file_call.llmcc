    }

    subgraph cluster_root_0_TMP_1_002_service_go {
      label="002_service.go";

      n4[label="Display", package="$TMP", file="002_service.go", path="$TMP/002_service.go:3", kind="function"];
    }

  }


n4 -> n2 [rel="call", from="caller", to="callee"];
