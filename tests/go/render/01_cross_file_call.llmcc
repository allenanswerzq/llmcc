===============================================================================
cross-file-call
===============================================================================
Function in one Go file calls a function defined in another file.
lang: go

--- file: go.mod ---
module sample

--- file: util.go ---
package sample

func FormatName(name string) string {
    return "user:" + name
}

--- file: service.go ---
package sample

func Display() string {
    return FormatName("Ada")
}

--- expect:arch-graph ---
