===============================================================================
multi-package-layout
===============================================================================
Go project with source split across cmd and pkg-style package directories.
lang: go

--- file: go.mod ---
module sample

--- file: pkg/model/user.go ---
package model

type User struct {
    Name string
}

func NewUser(name string) User {
    return User{Name: name}
}

--- file: cmd/app/main.go ---
package main

func Run() string {
    return BuildName("Ada")
}

func BuildName(name string) string {
    return name
}

