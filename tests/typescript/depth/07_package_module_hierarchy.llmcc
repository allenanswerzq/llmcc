===============================================================================
package-module-hierarchy
===============================================================================
Test that package.json is detected and creates proper crate/module hierarchy.
TypeScript projects use package.json to define packages (similar to Rust crates).
lang: typescript

--- file: package.json ---

{
  "name": "my-app",
  "version": "1.0.0"
}

--- file: src/index.ts ---

import { helper } from "./utils/helper";

export function main(): number {
    return helper();
}

--- file: src/utils/helper.ts ---

export function helper(): number {
    return 42;
}

--- expect:block-graph ---
(root:1 001_index (001_index)
  (func:2 main
    (return:3 @type number)
    (@fdep:6 helper)
  )
)

(root:5 002_helper (002_helper)
  (func:6 helper
    (return:7 @type number)
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_my_app {
    label="my-app";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_my_app_0_001_index_ts {
      label="001_index.ts";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="main", package="my-app", file="001_index.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/src/001_index.ts:4", kind="function", shape="ellipse"];
    }

    subgraph cluster_root_0_my_app_1_utils {
      label="utils";
      style=rounded;
      bgcolor="#f5f5f5";

      subgraph cluster_root_0_my_app_1_utils_0_002_helper_ts {
        label="002_helper.ts";
        style=rounded;
        bgcolor="#fafafa";

        n6[label="helper", package="my-app", module="utils", file="002_helper.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/src/utils/002_helper.ts:2", kind="function", shape="ellipse"];
      }

    }

  }


n2 -> n6 [rel="call", from="caller", to="callee"];
}
