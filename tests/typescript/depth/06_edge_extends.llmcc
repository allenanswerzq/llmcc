  )
  (interface:5 Timestamped
    (field:6 createdAt @type Date)
    (field:7 updatedAt @type Date)
  )
  (class:8 BaseModel
    (field:9 id @type number)
  )
)

(root:10 001_user (001_user)
  (interface:11 User @extends:2 Entity @extends:5 Timestamped
    (field:12 email @type string)
    (field:13 name @type string)
  )
  (class:14 UserModel @extends:8 BaseModel
    (field:15 email @type string)
    (field:16 name @type string)
  )
)

