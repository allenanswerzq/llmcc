===============================================================================
edge-extends
===============================================================================
Test that interface/class extends creates correct edge.
Child depends on parent.
lang: typescript

--- file: base/entity.ts ---

export interface Entity {
    id: number;
    createdAt: Date;
}

export interface Timestamped {
    createdAt: Date;
    updatedAt: Date;
}

export class BaseModel {
    id: number;
}

--- file: models/user.ts ---

import { Entity, Timestamped, BaseModel } from "../base/entity";

export interface User extends Entity, Timestamped {
    email: string;
    name: string;
}

export class UserModel extends BaseModel {
    email: string;
    name: string;
}

