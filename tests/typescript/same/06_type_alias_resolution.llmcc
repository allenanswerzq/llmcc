===============================================================================
type-alias-resolution
===============================================================================
Test that type aliases resolve correctly when there are same-named types.
lang: typescript

--- file: src/internal.ts ---

export interface Error {
    internalCode: number;
}

export type Result<T> = T | Error;

--- file: src/public.ts ---

interface Error {
    userMessage: string;
}

// Public Result uses public Error
type Result<T> = T | Error;

export class Api {
    lastError: Error;
}

--- expect:block-graph ---
(root:1 000_internal (000_internal)
  (interface:2 Error
    (field:3 internalCode @type number)
  )
  (alias:4 Result)
)

(root:5 001_public (001_public)
  (interface:6 Error
    (field:7 userMessage @type string)
  )
  (alias:8 Result)
  (class:9 Api
    (field:10 lastError @type:6 Error)
  )
)

