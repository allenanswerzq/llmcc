===============================================================================
prefer-same-module
===============================================================================
Test that symbol resolution prefers types defined in the same module/directory
over types with the same name in other modules.
lang: typescript

--- file: src/data/models.ts ---

// Entity defined in data module
export interface Entity {
    id: number;
}

--- file: src/data/helpers.ts ---

import { Entity } from "./models";

// Helper in same module uses Entity from same module
export interface EntityWrapper {
    inner: Entity;
}

--- file: src/services/handlers.ts ---

// Different Entity in services module
export interface Entity {
    name: string;
}

export class Handler {
    // Should resolve to local Entity (services module), not data::Entity
    entity: Entity;
}

--- expect:block-graph ---
(root:1 000_models (000_models)
  (interface:2 Entity
    (field:3 id @type number)
  )
)

(root:4 001_helpers (001_helpers)
  (interface:5 EntityWrapper
    (field:6 inner @type:2 Entity)
  )
)

(root:7 002_handlers (002_handlers)
  (interface:8 Entity
    (field:9 name @type string)
  )
  (class:10 Handler
    (field:11 entity @type:8 Entity)
  )
)

