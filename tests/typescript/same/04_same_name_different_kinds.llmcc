===============================================================================
same-name-different-kinds
===============================================================================
Test resolution when same name exists as different kinds (interface, class).
Type context should resolve appropriately.
lang: typescript

--- file: src/lib.ts ---

// Config as an interface
interface Config {
    value: number;
}

// Config as a class (different from interface)
class Config {
    settings: string;
}

// Holder uses Config as a type (should resolve to interface or class)
class Holder {
    config: Config;
}

// Implementor implements Config interface
class Implementor implements Config {
    value: number;
}

--- expect:block-graph ---
(root:1 000_lib (000_lib)
  (interface:2 Config
    (field:3 value @type number)
  )
  (class:4 Config
    (field:5 settings @type string)
  )
  (class:6 Holder
    (field:7 config @type:4 Config)
  )
  (class:8 Implementor
    (field:9 value @type number)
    (@tdep:4 Config)
  )
)

--- expect:arch-graph ---
