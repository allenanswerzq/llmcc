===============================================================================
generic-field-type
===============================================================================
Test that generic field types with concrete type arguments create edges.
lang: typescript

--- file: sample/src/lib.ts ---

class User {
    id: number;
    name: string;
}

class Container<T> {
    value: T;
}

class UserManager {
    users: Container<User>;
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_000_lib_ts {
    label="000_lib.ts";
    style=rounded;
    bgcolor="#fafafa";

