===============================================================================
interface-extends-multiple
===============================================================================
Test that an interface extending multiple interfaces creates edges to all of them.
lang: typescript

--- file: sample/src/lib.ts ---

interface Named {
    name: string;
}

interface Aged {
    age: number;
}

interface Located {
    location: string;
}

interface Person extends Named, Aged, Located {
    email: string;
}

--- expect:arch-graph ---
