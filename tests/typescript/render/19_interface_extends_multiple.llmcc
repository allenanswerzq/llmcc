===============================================================================
interface-extends-multiple
===============================================================================
Test that an interface extending multiple interfaces creates edges to all of them.
lang: typescript

--- file: sample/src/lib.ts ---

interface Named {
    name: string;
}

interface Aged {
    age: number;
}

interface Located {
    location: string;
}

interface Person extends Named, Aged, Located {
    email: string;
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_000_lib_ts {
    label="000_lib.ts";
    style=rounded;
    bgcolor="#fafafa";

    n2[label="Named", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:2", kind="interface", shape="box"];
    n4[label="Aged", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:6", kind="interface", shape="box"];
    n6[label="Located", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:10", kind="interface", shape="box"];
    n8[label="Person", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:14", kind="interface", shape="box"];
  }


n2 -> n8 [rel="specialization", from="base", to="specializes"];
n4 -> n8 [rel="specialization", from="base", to="specializes"];
n6 -> n8 [rel="specialization", from="base", to="specializes"];
