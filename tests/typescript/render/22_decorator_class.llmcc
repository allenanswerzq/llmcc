    (parameter:4 target @type any)
  )
  (func:5 Injectable
    (parameter:6 target @type any)
  )
  (class:7 AppComponent
    (field:10 title @type string)
    (@tdep:2 Component)
    (@tdep:5 Injectable)
  )
)

