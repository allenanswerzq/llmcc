===============================================================================
interface-impl
===============================================================================
Test that classes implementing interfaces create edges.
lang: typescript

--- file: sample/src/lib.ts ---

interface Printable {
    print(): void;
}

class Document implements Printable {
    content: string;

    print(): void {
        console.log(this.content);
    }
}

