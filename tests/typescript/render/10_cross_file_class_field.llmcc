===============================================================================
cross-file-class-field
===============================================================================
Test that cross-file class field types create edges.
lang: typescript

--- file: sample/src/models.ts ---

export class Product {
    id: number;
    name: string;
    price: number;
}

--- file: sample/src/cart.ts ---
import { Product } from './models';

export class CartItem {
    product: Product;
    quantity: number;
}

