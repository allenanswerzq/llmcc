===============================================================================
multiple-interface-impl
===============================================================================
Test that a class implementing multiple interfaces creates edges to all of them.
lang: typescript

--- file: sample/src/lib.ts ---

interface Serializable {
    serialize(): string;
}

interface Comparable {
    compareTo(other: Comparable): number;
}

interface Cloneable {
    clone(): Cloneable;
}

class Document implements Serializable, Comparable, Cloneable {
    content: string;

    serialize(): string {
        return this.content;
    }

    compareTo(other: Comparable): number {
        return 0;
    }

    clone(): Document {
        return new Document();
    }
}

