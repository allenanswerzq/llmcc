===============================================================================
cross-file-enum-field
===============================================================================
Test that cross-file enum field types create edges.
lang: typescript

--- file: sample/src/status.ts ---

export enum Status {
    Active,
    Inactive,
    Pending
}

--- file: sample/src/task.ts ---
import { Status } from './status';

export class Task {
    name: string;
    status: Status;
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_000_status_ts {
    label="000_status.ts";
    style=rounded;
    bgcolor="#fafafa";

    n2[label="Status", file="000_status.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_status.ts:2", kind="enum", shape="box"];
  }

  subgraph cluster_root_1_001_task_ts {
