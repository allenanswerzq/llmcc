===============================================================================
type-alias-edges
===============================================================================
Test that type aliases referencing classes create edges.
lang: typescript

--- file: sample/src/lib.ts ---

class User {
    id: number;
    name: string;
}

class Admin {
    id: number;
    role: string;
}

type Person = User | Admin;

type UserList = User[];

type UserMap = Map<string, User>;

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_000_lib_ts {
    label="000_lib.ts";
    style=rounded;
    bgcolor="#fafafa";

    n2[label="User", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:2", kind="struct", shape="box"];
    n5[label="Admin", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:7", kind="struct", shape="box"];
  }


}
