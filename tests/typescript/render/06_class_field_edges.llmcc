===============================================================================
class-field-edges
===============================================================================
Test that edges are drawn from classes to their field types.
lang: typescript

--- file: sample/src/lib.ts ---

class Address {
    street: string;
    city: string;
}

class Person {
    name: string;
    home: Address;
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_000_lib_ts {
    label="000_lib.ts";
    style=rounded;
    bgcolor="#fafafa";

    n2[label="Address", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:2", kind="struct", shape="box"];
    n5[label="Person", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:7", kind="struct", shape="box"];
  }


n2 -> n5 [rel="field", from="field_type", to="container"];
}
