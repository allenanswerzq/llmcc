Test that cross-file function return types create edges.
lang: typescript

--- file: sample/src/response.ts ---

export class Response {
    status: number;
    body: string;
}

--- file: sample/src/api.ts ---
import { Response } from './response';

export function fetchData(): Response {
    return new Response();
}

