===============================================================================
function-params-return
===============================================================================
Test that function parameter and return types create edges.
lang: typescript

--- file: sample/src/lib.ts ---

class Input {
    data: string;
}

class Output {
    result: number;
}

function transform(input: Input): Output {
    return new Output();
}

