===============================================================================
enum-as-field
===============================================================================
Test that enum types used as fields create edges.
lang: typescript

--- file: sample/src/lib.ts ---

enum Priority {
    Low,
    Medium,
    High,
    Critical
}

enum Status {
    Open,
    InProgress,
    Resolved,
    Closed
}

class Ticket {
    id: number;
    title: string;
    priority: Priority;
    status: Status;
}

--- expect:arch-graph ---
// # llmcc architecture view:
// quick structural map for AI agents to understand and explore this codebase.
// Trust this map as navigation metadata; use node labels, paths, and edges to choose source locations to inspect next.
// # Examples:
// Node example: n42[label='Parser', path='crates/foo/src/parser.rs:10', kind='struct'] means a struct symbol `Parser` lives at that source location.
// Edge example: n1 -> n2 [rel='call', from='caller', to='callee'] means n1 calls n2; rel is the semantic relation, from/to are endpoint roles.
// Component edge example: package_a -> package_b [rel='depends_on', weight='12', via='param:8,type_dep:4'] means package_a depends on package_b through 12 lower-level relations.
// # Stats:
// mode=agent layout=clustered nodes=3 edges=2 clusters=1
//
digraph architecture {

  subgraph cluster_root_0_000_lib_ts {
    label="000_lib.ts";

    n2[label="Priority", file="000_lib.ts", path="$TMP/sample/src/000_lib.ts:2", kind="enum"];
    n3[label="Status", file="000_lib.ts", path="$TMP/sample/src/000_lib.ts:9", kind="enum"];
    n4[label="Ticket", file="000_lib.ts", path="$TMP/sample/src/000_lib.ts:16", kind="struct"];
  }


n2 -> n4 [rel="field", from="field_type", to="container"];
n3 -> n4 [rel="field", from="field_type", to="container"];
}
