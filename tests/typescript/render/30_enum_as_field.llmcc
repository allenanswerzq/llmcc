===============================================================================
enum-as-field
===============================================================================
Test that enum types used as fields create edges.
lang: typescript

--- file: sample/src/lib.ts ---

enum Priority {
    Low,
    Medium,
    High,
    Critical
}

enum Status {
    Open,
    InProgress,
    Resolved,
    Closed
}

class Ticket {
    id: number;
    title: string;
    priority: Priority;
    status: Status;
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_000_lib_ts {
    label="000_lib.ts";
    style=rounded;
    bgcolor="#fafafa";

    n2[label="Priority", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:2", kind="enum", shape="box"];
    n3[label="Status", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:9", kind="enum", shape="box"];
    n4[label="Ticket", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:16", kind="struct", shape="box"];
  }


n2 -> n4 [rel="field", from="field_type", to="container"];
n3 -> n4 [rel="field", from="field_type", to="container"];
}
