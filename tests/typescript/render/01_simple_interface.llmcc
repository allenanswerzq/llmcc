===============================================================================
simple-interface
===============================================================================
Test that a simple interface appears in the architecture graph.
lang: typescript

--- file: sample/src/lib.ts ---

interface User {
    name: string;
    age: number;
}

interface Admin extends User {
    role: string;
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_000_lib_ts {
    label="000_lib.ts";
    style=rounded;
    bgcolor="#fafafa";

    n2[label="User", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:2", kind="interface", shape="box"];
    n5[label="Admin", file="000_lib.ts", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/000_lib.ts:7", kind="interface", shape="box"];
  }


n2 -> n5 [rel="specialization", from="base", to="specializes"];
}
