(root:1 000_lib (000_lib)
  (module:2 Models (inline)
    (class:3 User
      (field:4 id @type number)
      (field:5 name @type string)
    )
    (class:6 Order
      (field:7 id @type number)
      (field:8 user @type:8 user)
    )
  )
  (module:9 Services (inline)
    (class:10 UserService
      (method:11 getUser
        (parameter:12 id @type number)
        (return:13 @type:2 Models)
      )
    )
  )
)

