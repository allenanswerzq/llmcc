===============================================================================
namespace
===============================================================================
Test that namespaces with nested types appear correctly.
lang: typescript

--- file: sample/src/lib.ts ---

namespace Models {
    export class User {
        id: number;
        name: string;
    }

    export class Order {
        id: number;
        user: User;
    }
}

namespace Services {
    export class UserService {
        getUser(id: number): Models.User {
            return new Models.User();
        }
    }
}

