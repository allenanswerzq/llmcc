===============================================================================
cross-file-reference
===============================================================================
Test that types defined in different files create edges.
lang: typescript

--- file: sample/src/types.ts ---

export class User {
    id: number;
    name: string;
}

--- file: sample/src/services.ts ---
import { User } from './types';

export class UserService {
    currentUser: User;
}

export function getUser(): User {
    return new User();
}

--- expect:block-graph ---
(root:1 000_types (000_types)
  (class:2 User
    (field:3 id @type number)
    (field:4 name @type string)
  )
)

(root:5 001_services (001_services)
  (class:6 UserService
    (field:7 currentUser @type:2 User)
  )
  (func:8 getUser
    (return:9 @type:2 User)
    (@tdep:2 User)
  )
)

