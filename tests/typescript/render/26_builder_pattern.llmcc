===============================================================================
builder-pattern
===============================================================================
Test builder pattern with method chaining and type references.
lang: typescript

--- file: sample/src/lib.ts ---

class Config {
    host: string;
    port: number;
    timeout: number;
}

class ConfigBuilder {
    config: Config;

    constructor() {
        this.config = new Config();
    }

    setHost(host: string): ConfigBuilder {
        this.config.host = host;
        return this;
    }

    setPort(port: number): ConfigBuilder {
        this.config.port = port;
        return this;
    }

    setTimeout(timeout: number): ConfigBuilder {
        this.config.timeout = timeout;
        return this;
    }

    build(): Config {
        return this.config;
    }
}

