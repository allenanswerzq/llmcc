===============================================================================
cross-file-call
===============================================================================
Method in one C# file calls a method defined in another file.
lang: csharp

--- file: project.csproj ---
<Project Sdk="Microsoft.NET.Sdk"></Project>

--- file: Formatter.cs ---
namespace Sample;

public class Formatter {
    public string Format(string name) {
        return "user:" + name;
    }
}

--- file: UserService.cs ---
namespace Sample;

public class UserService {
    public string Display(string name) {
        return Format(name);
    }
}

