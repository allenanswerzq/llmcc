===============================================================================
inheritance
===============================================================================

lang: csharp

--- file: Program.cs ---
namespace MyApp;

public class Shape {
    public double X { get; set; }
    public double Y { get; set; }

    public virtual double Area() => 0;
}

public class Circle : Shape {
    public double Radius { get; set; }

    public override double Area() => Math.PI * Radius * Radius;
}

--- expect:block-graph ---
(root:1  (000_Program)
  (class:2 Shape
    (method:3 Area)
  )
  (class:4 Circle
    (method:5 Area)
  )
)




===============================================================================
struct-and-methods
===============================================================================

lang: csharp

--- file: Program.cs ---
namespace MyApp;

public struct Point {
    public int X;
    public int Y;

    public Point(int x, int y) {
        X = x;
        Y = y;
    }

    public double Distance(Point other) {
        return Math.Sqrt(Math.Pow(X - other.X, 2) + Math.Pow(Y - other.Y, 2));
    }
}

--- expect:block-graph ---
(root:1  (000_Program)
  (class:2 Point
    (method:3 Point)
    (method:4 Distance
    )
  )
)
