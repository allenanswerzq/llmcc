namespace MyApp;

public interface IRepository {
    void Save(string data);
    string Load(int id);
}

public class FileRepository : IRepository {
    public string BasePath { get; set; }

    public void Save(string data) {
        // save to file
    }

    public string Load(int id) {
        return "";
    }
}

