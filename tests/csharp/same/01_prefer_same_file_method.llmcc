===============================================================================
prefer-same-file-method
===============================================================================
When methods share a name, call resolution should prefer the method in the same file.
lang: csharp

--- file: project.csproj ---
<Project Sdk="Microsoft.NET.Sdk"></Project>

--- file: GlobalRules.cs ---
namespace Sample;

public class GlobalRules {
    public bool Validate() {
        return false;
    }
}

--- file: Service.cs ---
namespace Sample;

public class Service {
    public bool Validate() {
        return true;
    }

    public bool Run() {
        return Validate();
    }
}

