  package_backend_core[label="backend-core", kind="package", package="backend-core", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/backend/core"];
package_backend_api -> package_backend_core [rel="depends_on", weight="1", via="field:1"];
  compound=true;
