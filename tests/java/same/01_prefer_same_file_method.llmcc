===============================================================================
prefer-same-file-method
===============================================================================
When methods share a name, call resolution should prefer the method in the same file.
lang: java

--- file: pom.xml ---
<project><modelVersion>4.0.0</modelVersion></project>

--- file: src/main/java/com/example/GlobalRules.java ---
package com.example;

public class GlobalRules {
    public boolean validate() {
        return false;
    }
}

--- file: src/main/java/com/example/Service.java ---
package com.example;

public class Service {
    public boolean validate() {
        return true;
    }

    public boolean run() {
        return validate();
    }
}

