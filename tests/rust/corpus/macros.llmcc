===============================================================================
macro-invocation-arbitrary-tokens
===============================================================================


--- file: src/lib.rs ---

a!(* a *);
a!(& a &);
a!(- a -);
a!(b + c + +);
a!('a'..='z');
a!('\u{0}'..='\u{2}');
a!('lifetime)
default!(a);
union!(a);
a!($);
a!($());
a!($ a $);
a!(${$([ a ])});
a!($a $a:ident $($a);*);

--- expect:block-graph ---
(root:1 000_lib (000_lib)
)




