===============================================================================
macro-definition
===============================================================================


--- file: src/lib.rs ---

macro_rules! say_hello {
    () => (
        println!("Hello!");
    )
}

macro_rules! four {
    () => {1 + 3};
}

macro_rules! foo {
    (x => $e:expr) => (println!("mode X: {}", $e));
    (y => $e:expr) => (println!("mode Y: {}", $e))
}

macro_rules! o_O {
    (
      $($x:expr; [ $( $y:expr ),* ]);*
    ) => {
      $($($x + $e),*),*
    }
}

macro_rules! zero_or_one {
    ($($e:expr),?) => {
        $($e),?
    };
}

macro_rules! empty [
    () => {};
];

--- expect:block-graph ---
(root:1 000_lib (000_lib)
  (func:2 say_hello)
  (func:3 four)
  (func:4 foo)
  (func:5 o_O)
  (func:6 zero_or_one)
  (func:7 empty)
)
