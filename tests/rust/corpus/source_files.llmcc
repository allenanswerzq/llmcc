//!  - Inner line doc
//!! - Still an inner line doc (but with a bang at the beginning)
//   - Only a comment
///  - Outer line doc (exactly 3 slashes)
///
//// - Only a comment
---
(source_file
  (line_comment
    inner: (inner_doc_comment_marker)
    doc: (doc_comment))
  (line_comment
    inner: (inner_doc_comment_marker)
    doc: (doc_comment))
  (line_comment)
  (line_comment
    outer: (outer_doc_comment_marker)
    doc: (doc_comment))
  (line_comment
    outer: (outer_doc_comment_marker)
    doc: (doc_comment))
  (line_comment))




