block-doc-comments
===============================================================================
/*!  - Inner block doc */
/*!! - Still an inner block doc (but with a bang at the beginning) */
/*   - Only a comment */
/**  - Outer block doc (exactly) 2 asterisks */
/*** - Only a comment */
----
(source_file
  (block_comment
    inner: (inner_doc_comment_marker)
    doc: (doc_comment))
  (block_comment
    inner: (inner_doc_comment_marker)
    doc: (doc_comment))
  (block_comment)
  (block_comment
    outer: (outer_doc_comment_marker)
    doc: (doc_comment))
  (block_comment))




