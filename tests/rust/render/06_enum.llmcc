===============================================================================
enum-variants
===============================================================================
Test that enums appear in the architecture graph.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---

struct Input {
    data: Vec<u8>,
}

pub enum Status {
    Pending,
    Active,
    InputItem {
        data: Vec<Input>,
        foo: i32,
    },
}

pub enum Result<T, E> {
    Ok(T),
    Err(E),
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (class:2 Input
    (field:3 data @type data)
  )
  (enum:4 Status
    (field:5 Pending)
    (field:6 Active)
    (field:7 InputItem
      (field:8 data @type:2 Input)
      (field:9 foo @type i32)
    )
  )
  (enum:10 Result
    (field:11 Ok
      (field:12 0 @type T)
    )
    (field:13 Err
      (field:14 0 @type E)
    )
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Input", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:2", kind="struct", shape="box"];
      n4[label="Status", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:6", kind="enum", shape="box"];
      n10[label="Result", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:15", kind="enum", shape="box"];
    }

  }


n2 -> n4 [rel="field", from="field_type", to="container"];
}
