===============================================================================
nested-module-structure
===============================================================================
Nested modules with pub use re-exports.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
pub mod db;
pub use db::Connection;

--- file: sample/src/db/mod.rs ---
mod pool;
pub use pool::Connection;

pub struct Config {
    pub host: String,
    pub port: u16,
}

--- file: sample/src/db/pool.rs ---
use super::Config;

pub struct Connection {
    pub config: Config,
    pub active: bool,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 db)
)

(root:3 002_mod (002_mod)
  (module:4 pool)
  (class:5 Config
    (field:6 host @type String)
    (field:7 port @type u16)
  )
)

(root:8 003_pool (003_pool)
  (class:9 Connection
    (field:10 config @type:5 Config)
    (field:11 active @type bool)
    (@tdep:5 Config)
  )
)

--- expect:arch-graph ---
