      }

      subgraph cluster_root_0_sample_0_db_1_003_pool_rs {
        label="003_pool.rs";

        n9[label="Connection", package="sample", module="db", file="003_pool.rs", path="$TMP/sample/src/db/003_pool.rs:3", kind="struct"];
