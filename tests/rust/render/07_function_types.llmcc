===============================================================================
function-params-return
===============================================================================
Test that function parameter and return types create edges.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---


pub struct Input {
    pub data: String,
}

pub struct Output {
    pub result: i32,
}

pub fn transform(input: Input) -> Output {
    Output { result: input.data.len() as i32 }
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Input", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:3", kind="struct", shape="box"];
      n4[label="Output", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:7", kind="struct", shape="box"];
      n6[label="transform", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:11", kind="function", shape="ellipse"];
    }

  }


n2 -> n6 [rel="param", from="input", to="func"];
n6 -> n4 [rel="return", from="func", to="output"];
}
