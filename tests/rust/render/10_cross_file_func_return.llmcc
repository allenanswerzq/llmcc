===============================================================================
cross-file-func-return
===============================================================================
Function in one file returns struct from another file.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod factory;

--- file: sample/src/types.rs ---
pub struct Config {
    pub name: String,
}

--- file: sample/src/factory.rs ---
use crate::types::Config;

pub fn create_config() -> Config {
    Config { name: "default".to_string() }
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 factory)
)

(root:4 002_types (002_types)
  (class:5 Config
    (field:6 name @type String)
  )
)

(root:7 003_factory (003_factory)
  (func:8 create_config
    (return:9 @type:5 Config)
    (@tdep:5 Config)
  )
)

