===============================================================================
trait-bound-param
===============================================================================
Function with trait-bounded generic parameter creates a type dependency.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
pub trait Encode {
    fn encode(&self) -> Vec<u8>;
}

pub struct Payload {
    pub data: Vec<u8>,
}

impl Encode for Payload {
    fn encode(&self) -> Vec<u8> {
        self.data.clone()
    }
}

pub fn send<T: Encode>(item: &T) -> usize {
    item.encode().len()
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (trait:2 Encode
    (method:3 encode
      (parameter:4 self @type:2 Encode)
      (return:5)
    )
  )
  (class:6 Payload
    (field:7 data @type data)
  )
  (impl:8 Payload @type:6 @trait:2
    (method:9 encode
      (parameter:10 self @type:6 Payload)
      (return:11)
    )
  )
  (func:13 send
    (parameter:14 item @type:2 Encode)
    (return:15 @type usize)
  )
)

