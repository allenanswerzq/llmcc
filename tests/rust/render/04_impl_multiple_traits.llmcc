      label="001_lib.rs";

      n2[label="Serialize", package="sample", file="001_lib.rs", path="$TMP/sample/src/001_lib.rs:1", kind="trait"];
      n6[label="Validate", package="sample", file="001_lib.rs", path="$TMP/sample/src/001_lib.rs:5", kind="trait"];
      n10[label="Message", package="sample", file="001_lib.rs", path="$TMP/sample/src/001_lib.rs:9", kind="struct"];
