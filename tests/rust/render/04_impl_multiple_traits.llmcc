===============================================================================
impl-multiple-traits
===============================================================================
One struct implements multiple traits, creating multiple conformance edges.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
pub trait Serialize {
    fn serialize(&self) -> Vec<u8>;
}

pub trait Validate {
    fn validate(&self) -> bool;
}

pub struct Message {
    pub body: String,
}

impl Serialize for Message {
    fn serialize(&self) -> Vec<u8> {
        self.body.as_bytes().to_vec()
    }
}

impl Validate for Message {
    fn validate(&self) -> bool {
        !self.body.is_empty()
    }
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (trait:2 Serialize
    (method:3 serialize
      (parameter:4 self @type:2 Serialize)
      (return:5)
    )
  )
  (trait:6 Validate
    (method:7 validate
      (parameter:8 self @type:6 Validate)
      (return:9 @type bool)
    )
  )
  (class:10 Message
    (field:11 body @type String)
  )
  (impl:12 Message @type:10 @trait:2
    (method:13 serialize
      (parameter:14 self @type:10 Message)
      (return:15)
    )
  )
  (impl:17 Message @type:10 @trait:6
    (method:18 validate
      (parameter:19 self @type:10 Message)
      (return:20 @type bool)
    )
  )
)

--- expect:arch-graph ---
