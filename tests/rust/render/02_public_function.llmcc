===============================================================================
public-function
===============================================================================
Test that public free functions appear in the architecture graph,
but private functions do not.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---

struct Input;
enum Output {}
struct Foo;
impl Foo {
    fn new() -> Foo {}
}

pub fn process_data(input: Input) -> Output {
    let f = Foo::new();
    helper(input)
}

fn helper(s: Input) -> Output {
    Output
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (class:2 Input)
  (enum:3 Output)
  (class:4 Foo)
  (impl:5 Foo @type:4
    (method:6 new
      (return:7 @type:4 Foo)
      (@tdep:4 Foo)
    )
  )
  (func:8 process_data
    (parameter:9 input @type:2 Input)
    (return:10 @type:3 Output)
    (@tdep:2 Input)
    (@tdep:3 Output)
    (@tdep:4 Foo)
    (@fdep:6 new)
  )
  (func:13 helper
    (parameter:14 s @type:2 Input)
    (return:15 @type:3 Output)
    (@tdep:2 Input)
    (@tdep:3 Output)
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Input", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:2", kind="struct", shape="box"];
      n3[label="Output", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:3", kind="enum", shape="box"];
      n4[label="Foo", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:4", kind="struct", shape="box"];
      n8[label="process_data", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:9", kind="function", shape="ellipse"];
      n13[label="helper", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:14", kind="function", shape="ellipse"];
    }

  }


n2 -> n8 [rel="param", from="input", to="func"];
n2 -> n13 [rel="param", from="input", to="func"];
n8 -> n3 [rel="return", from="func", to="output"];
n8 -> n4 [rel="type_dep", from="source", to="type_dep"];
n13 -> n3 [rel="return", from="func", to="output"];
}
