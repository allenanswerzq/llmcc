===============================================================================
enum-with-generic-variants
===============================================================================
Test enums with generic type parameters in variants.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod containers;

--- file: sample/src/types.rs ---
pub struct User {
    pub id: u64,
}

pub struct Error {
    pub code: i32,
}

pub struct Config {
    pub key: String,
}

--- file: sample/src/containers.rs ---
use crate::types::{User, Error, Config};

pub enum Option<T> {
    Some(T),
    None,
}

pub enum Result<T, E> {
    Ok(T),
    Err(E),
}

// Concrete uses of generic enums
pub struct UserOption {
    pub user: Option<User>,
}

pub struct UserResult {
    pub result: Result<User, Error>,
}

pub struct ConfigResult {
    pub config: Result<Config, Error>,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 containers)
)

(root:4 002_types (002_types)
  (class:5 User
    (field:6 id @type u64)
  )
  (class:7 Error
    (field:8 code @type i32)
  )
  (class:9 Config
    (field:10 key @type String)
  )
)

(root:11 003_containers (003_containers)
  (enum:12 Option
    (field:13 Some
      (field:14 0 @type T)
    )
    (field:15 None)
  )
  (enum:16 Result
    (field:17 Ok
      (field:18 0 @type T)
    )
    (field:19 Err
      (field:20 0 @type E)
    )
  )
  (class:21 UserOption
    (field:22 user @type:12 Option)
    (@tdep:12 Option)
  )
  (class:23 UserResult
    (field:24 result @type:16 Result)
    (@tdep:16 Result)
  )
  (class:25 ConfigResult
    (field:26 config @type:16 Result)
    (@tdep:16 Result)
  )
)

