===============================================================================
multiple-generic-params
===============================================================================
Tests for types with multiple generic parameters like Result<T, E>, HashMap<K, V>, etc.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod services;

--- file: sample/src/types.rs ---
pub struct User {
    pub id: u64,
}

pub struct Error {
    pub code: i32,
    pub message: String,
}

pub struct Config {
    pub key: String,
}

--- file: sample/src/services.rs ---
use std::collections::HashMap;
use crate::types::{User, Error, Config};

// Result with two user types
pub fn get_user() -> Result<User, Error> {
    todo!()
}

// HashMap with two user types
pub struct UserConfigMap {
    pub configs: HashMap<User, Config>,
}

// Custom generic struct with multiple params
pub struct Pair<A, B> {
    pub first: A,
    pub second: B,
}

// Using custom generic with user types
pub struct UserErrorPair {
    pub pair: Pair<User, Error>,
}

// Triple generic params
pub struct Triple<A, B, C> {
    pub a: A,
    pub b: B,
    pub c: C,
}

// Using triple generic
pub struct AllThree {
    pub data: Triple<User, Error, Config>,
}

