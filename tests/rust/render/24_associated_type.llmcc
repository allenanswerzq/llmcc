--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod container;
mod string_holder;

--- file: sample/src/container.rs ---
pub trait Container {
    type Item;
    fn get(&self) -> Self::Item;
}

--- file: sample/src/string_holder.rs ---
use crate::container::Container;

pub struct StringHolder {
    pub value: String,
}

impl Container for StringHolder {
    type Item = String;
    fn get(&self) -> Self::Item {
        self.value.clone()
    }
}

