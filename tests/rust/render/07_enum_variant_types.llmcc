===============================================================================
enum-variant-types
===============================================================================
Enum variants with associated data referencing types from other files.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod events;

--- file: sample/src/types.rs ---
pub struct User {
    pub name: String,
}

pub struct Order {
    pub id: u64,
}

--- file: sample/src/events.rs ---
use crate::types::{User, Order};

pub enum Event {
    UserCreated(User),
    OrderPlaced { order: Order, by: User },
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 events)
)

(root:4 002_types (002_types)
  (class:5 User
    (field:6 name @type String)
  )
  (class:7 Order
    (field:8 id @type u64)
  )
)

(root:9 003_events (003_events)
  (enum:10 Event
    (field:11 UserCreated
      (field:12 0 @type:5 User)
    )
    (field:13 OrderPlaced
      (field:14 order @type:7 Order)
      (field:15 by @type:5 User)
    )
  )
)

