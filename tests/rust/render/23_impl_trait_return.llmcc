===============================================================================
impl-trait-return
===============================================================================
Function returns impl Trait.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod iterator;
mod factory;

--- file: sample/src/iterator.rs ---
pub trait Iterator {
    fn next(&self) -> Option<i32>;
}

--- file: sample/src/factory.rs ---
use crate::iterator::Iterator;

pub struct Counter {
    count: i32,
}

impl Iterator for Counter {
    fn next(&self) -> Option<i32> {
        Some(self.count)
    }
}

pub fn make_counter() -> impl Iterator {
    Counter { count: 0 }
}

