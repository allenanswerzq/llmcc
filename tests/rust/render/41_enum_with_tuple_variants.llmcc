===============================================================================
enum-with-tuple-variants
===============================================================================
Test enums with tuple-like variants containing user-defined types.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod results;

--- file: sample/src/types.rs ---
pub struct Data {
    pub value: i32,
}

pub struct ErrorInfo {
    pub code: i32,
}

--- file: sample/src/results.rs ---
use crate::types::{Data, ErrorInfo};

pub enum Result {
    Ok(Data),
    Err(ErrorInfo),
}

pub enum MultiResult {
    Success(Data, Data),
    Partial(Data, ErrorInfo),
    Failure(ErrorInfo),
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 results)
)

(root:4 002_types (002_types)
  (class:5 Data
    (field:6 value @type i32)
  )
  (class:7 ErrorInfo
    (field:8 code @type i32)
  )
)

(root:9 003_results (003_results)
  (enum:10 Result
    (field:11 Ok
      (field:12 0 @type:5 Data)
    )
    (field:13 Err
      (field:14 0 @type:7 ErrorInfo)
    )
  )
  (enum:15 MultiResult
    (field:16 Success
      (field:17 0 @type:5 Data)
      (field:18 1 @type:5 Data)
    )
    (field:19 Partial
      (field:20 0 @type:5 Data)
      (field:21 1 @type:7 ErrorInfo)
    )
    (field:22 Failure
      (field:23 0 @type:7 ErrorInfo)
    )
  )
)

