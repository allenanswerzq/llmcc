===============================================================================
trait-and-impl
===============================================================================
Test that traits and their implementations create edges.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---

pub trait Printable {
    fn print(&self);
}

pub struct Document {
    pub content: String,
}

impl Printable for Document {
    fn print(&self) {
        println!("{}", self.content);
    }
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Printable", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:2", kind="trait", shape="box"];
      n5[label="Document", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:6", kind="struct", shape="box"];
    }

  }


n2 -> n5 [rel="conformance", from="contract", to="conforms"];
