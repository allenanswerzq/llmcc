===============================================================================
trait-bound-param
===============================================================================
Function with trait bound in parameter type.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod display;
mod formatter;

--- file: sample/src/display.rs ---
pub trait Display {
    fn display(&self) -> String;
}

--- file: sample/src/formatter.rs ---
use crate::display::Display;

pub fn format_item<T: Display>(item: T) -> String {
    item.display()
}

