===============================================================================
cross-file-generic-field
===============================================================================
Struct field uses Vec<T> where T is from another file.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod item;
mod collection;

--- file: sample/src/item.rs ---
pub struct Task {
    pub name: String,
}

--- file: sample/src/collection.rs ---
use crate::item::Task;

pub struct TaskList {
    pub tasks: Vec<Task>,
}

