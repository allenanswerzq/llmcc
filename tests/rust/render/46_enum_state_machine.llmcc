===============================================================================
enum-state-machine
===============================================================================
Test enums used as a state machine pattern with transitions.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod state;

--- file: sample/src/types.rs ---
pub struct Order {
    pub id: u64,
}

pub struct Payment {
    pub amount: f64,
}

pub struct Shipment {
    pub tracking: String,
}

pub struct Cancellation {
    pub reason: String,
}

--- file: sample/src/state.rs ---
use crate::types::{Order, Payment, Shipment, Cancellation};

pub enum OrderState {
    Created { order: Order },
    Paid { order: Order, payment: Payment },
    Shipped { order: Order, shipment: Shipment },
    Delivered { order: Order, shipment: Shipment },
    Cancelled { order: Order, cancellation: Cancellation },
}

pub fn transition(state: OrderState) -> OrderState {
    state
}

