===============================================================================
super-scoped-path
===============================================================================
Uses super:: prefix for parent module paths.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
pub struct Base {
    pub id: u32,
}

mod inner {
    pub struct Child {
        pub base: super::Base,
    }
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (class:2 Base
    (field:3 id @type u32)
  )
  (module:4 inner (inline)
    (class:5 Child
      (field:6 base @type:2 Base)
      (@tdep:2 Base)
    )
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Base", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:1", kind="struct", shape="box"];
      n5[label="Child", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:6", kind="struct", shape="box"];
    }

  }


n2 -> n5 [rel="field", from="field_type", to="container"];
