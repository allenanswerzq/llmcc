===============================================================================
enum-as-field-type
===============================================================================
Test enums used as field types in structs.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod models;

--- file: sample/src/types.rs ---
pub enum Status {
    Active,
    Inactive,
    Pending,
}

pub enum Priority {
    Low,
    Medium,
    High,
}

--- file: sample/src/models.rs ---
use crate::types::{Status, Priority};

pub struct Task {
    pub name: String,
    pub status: Status,
    pub priority: Priority,
}

pub struct Project {
    pub title: String,
    pub status: Status,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 models)
)

(root:4 002_types (002_types)
  (enum:5 Status
    (field:6 Active)
    (field:7 Inactive)
    (field:8 Pending)
  )
  (enum:9 Priority
    (field:10 Low)
    (field:11 Medium)
    (field:12 High)
  )
)

(root:13 003_models (003_models)
  (class:14 Task
    (field:15 name @type String)
    (field:16 status @type:5 Status)
    (field:17 priority @type:9 Priority)
    (@tdep:5 Status)
    (@tdep:9 Priority)
  )
  (class:18 Project
    (field:19 title @type String)
    (field:20 status @type:5 Status)
    (@tdep:5 Status)
  )
)

