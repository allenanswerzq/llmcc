===============================================================================
cross-file-struct-field
===============================================================================
Struct in one file uses struct from another file as field type.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod model;
mod container;

--- file: sample/src/model.rs ---
pub struct Item {
    pub id: u64,
}

--- file: sample/src/container.rs ---
use crate::model::Item;

pub struct Box {
    pub item: Item,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 model)
  (module:3 container)
)

(root:4 002_model (002_model)
  (class:5 Item
    (field:6 id @type u64)
  )
)

(root:7 003_container (003_container)
  (class:8 Box
    (field:9 item @type:5 Item)
    (@tdep:5 Item)
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_002_model_rs {
      label="002_model.rs";
      style=rounded;
      bgcolor="#fafafa";

      n5[label="Item", package="sample", file="002_model.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/002_model.rs:1", kind="struct", shape="box"];
    }

    subgraph cluster_root_0_sample_1_003_container_rs {
      label="003_container.rs";
      style=rounded;
      bgcolor="#fafafa";

      n8[label="Box", package="sample", file="003_container.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/003_container.rs:3", kind="struct", shape="box"];
    }

  }


n5 -> n8 [rel="field", from="field_type", to="container"];
}
