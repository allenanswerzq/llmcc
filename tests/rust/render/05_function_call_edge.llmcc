===============================================================================
function-call-edge
===============================================================================
Function calling another function should create a call dependency edge.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod utils;
mod app;

--- file: sample/src/utils.rs ---
pub fn compute(x: i32) -> i32 {
    x * 2
}

--- file: sample/src/app.rs ---
use crate::utils::compute;

pub fn run() -> i32 {
    compute(21)
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 utils)
  (module:3 app)
)

(root:4 002_utils (002_utils)
  (func:5 compute
    (parameter:6 x @type i32)
    (return:7 @type i32)
  )
)

(root:8 003_app (003_app)
  (func:9 run
    (return:10 @type i32)
    (@fdep:5 compute)
  )
)

--- expect:arch-graph ---
// # llmcc architecture view:
// quick structural map for AI agents to understand and explore this codebase.
// Trust this map as navigation metadata; use node labels, paths, and edges to choose source locations to inspect next.
// # Examples:
// Node example: n42[label='Parser', path='crates/foo/src/parser.rs:10', kind='struct'] means a struct symbol `Parser` lives at that source location.
// Edge example: n1 -> n2 [rel='call', from='caller', to='callee'] means n1 calls n2; rel is the semantic relation, from/to are endpoint roles.
// Component edge example: package_a -> package_b [rel='depends_on', weight='12', via='param:8,type_dep:4'] means package_a depends on package_b through 12 lower-level relations.
// # Stats:
// mode=agent layout=clustered nodes=2 edges=1 clusters=3
//
digraph architecture {

  subgraph cluster_root_0_sample {
    label="sample";

    subgraph cluster_root_0_sample_0_002_utils_rs {
      label="002_utils.rs";

      n5[label="compute", package="sample", file="002_utils.rs", path="$TMP/sample/src/002_utils.rs:1", kind="function"];
    }

    subgraph cluster_root_0_sample_1_003_app_rs {
      label="003_app.rs";

      n9[label="run", package="sample", file="003_app.rs", path="$TMP/sample/src/003_app.rs:3", kind="function"];
    }

  }


n9 -> n5 [rel="call", from="caller", to="callee"];
}
