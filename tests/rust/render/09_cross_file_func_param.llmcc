===============================================================================
cross-file-func-param
===============================================================================
Function in one file takes struct from another file as parameter.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod handler;

--- file: sample/src/types.rs ---
pub struct Request {
    pub body: String,
}

--- file: sample/src/handler.rs ---
use crate::types::Request;

pub fn handle(req: Request) {
    println!("{}", req.body);
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 handler)
)

(root:4 002_types (002_types)
  (class:5 Request
    (field:6 body @type String)
  )
)

(root:7 003_handler (003_handler)
  (func:8 handle
    (parameter:9 req @type:5 Request)
    (@tdep:5 Request)
  )
)

