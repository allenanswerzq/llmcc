===============================================================================
self-scoped-path
===============================================================================
Uses self:: prefix for module-relative paths.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod utils;

--- file: sample/src/utils.rs ---
mod helper;

pub struct Wrapper {
    pub inner: ::helper::Helper,
}

--- file: sample/src/utils/helper.rs ---
pub struct Helper {
    pub id: u32,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 utils)
)

(root:3 002_utils (002_utils)
  (module:4 helper)
  (class:5 Wrapper
    (field:6 inner @type:8 Helper)
    (@tdep:8 Helper)
  )
)

(root:7 003_helper (003_helper)
  (class:8 Helper
    (field:9 id @type u32)
  )
)

