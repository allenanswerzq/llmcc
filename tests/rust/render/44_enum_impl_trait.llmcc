===============================================================================
enum-impl-trait
===============================================================================
Test enums implementing traits.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;

--- file: sample/src/types.rs ---
pub trait Displayable {
    fn display(&self) -> String;
}

pub trait Processable {
    fn process(&self);
}

pub enum Status {
    Active,
    Inactive,
    Pending,
}

pub enum Priority {
    Low,
    High,
}

impl Displayable for Status {
    fn display(&self) -> String {
        String::new()
    }
}

impl Processable for Status {
    fn process(&self) {}
}

impl Displayable for Priority {
    fn display(&self) -> String {
        String::new()
    }
}

