digraph architecture {

  subgraph cluster_root_0_sample {
    label="sample";

    subgraph cluster_root_0_sample_0_002_model_rs {
      label="002_model.rs";

      n5[label="Request", package="sample", file="002_model.rs", path="$TMP/sample/src/002_model.rs:1", kind="struct"];
      n7[label="Response", package="sample", file="002_model.rs", path="$TMP/sample/src/002_model.rs:5", kind="struct"];
    }

    subgraph cluster_root_0_sample_1_003_handler_rs {
      label="003_handler.rs";

      n10[label="handle", package="sample", file="003_handler.rs", path="$TMP/sample/src/003_handler.rs:3", kind="function"];
    }

  }


n5 -> n10 [rel="param", from="input", to="func"];
n10 -> n7 [rel="return", from="func", to="output"];
}
