===============================================================================
cross-file-func-param
===============================================================================
Function parameter references a type from another file.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod model;
mod handler;

--- file: sample/src/model.rs ---
pub struct Request {
    pub path: String,
}

pub struct Response {
    pub status: u16,
}

--- file: sample/src/handler.rs ---
use crate::model::{Request, Response};

pub fn handle(req: Request) -> Response {
    Response { status: 200 }
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 model)
  (module:3 handler)
)

(root:4 002_model (002_model)
  (class:5 Request
    (field:6 path @type String)
  )
  (class:7 Response
    (field:8 status @type u16)
  )
)

(root:9 003_handler (003_handler)
  (func:10 handle
    (parameter:11 req @type:5 Request)
    (return:12 @type:7 Response)
    (@tdep:5 Request)
    (@tdep:7 Response)
  )
)

--- expect:arch-graph ---
