  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_002_types_rs {
      label="002_types.rs";
      style=rounded;
      bgcolor="#fafafa";

      n5[label="User", package="sample", file="002_types.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/002_types.rs:2", kind="struct", shape="box"];
    }

    subgraph cluster_root_0_sample_1_003_services_rs {
      label="003_services.rs";
      style=rounded;
      bgcolor="#fafafa";

      n9[label="UserService", package="sample", file="003_services.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/003_services.rs:3", kind="struct", shape="box"];
      n11[label="get_user", package="sample", file="003_services.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/003_services.rs:7", kind="function", shape="ellipse"];
    }

  }


n5 -> n9 [rel="field", from="field_type", to="container"];
