===============================================================================
cross-file-reference
===============================================================================
Test that types defined in different files within the same crate create edges.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod services;

pub use types::User;
pub use services::UserService;

--- file: sample/src/types.rs ---

pub struct User {
    pub id: u64,
    pub name: String,
}

--- file: sample/src/services.rs ---
use crate::types::User;

pub struct UserService {
    pub current_user: User,
}

pub fn get_user() -> User {
    User { id: 1, name: "Alice".to_string() }
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 services)
)

(root:4 002_types (002_types)
  (class:5 User
    (field:6 id @type u64)
    (field:7 name @type String)
  )
)

(root:8 003_services (003_services)
  (class:9 UserService
    (field:10 current_user @type:5 User)
    (@tdep:5 User)
  )
  (func:11 get_user
    (return:12 @type:5 User)
    (@tdep:5 User)
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
