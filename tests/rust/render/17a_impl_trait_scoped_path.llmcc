===============================================================================
impl-trait-scoped-path
===============================================================================
Struct implements trait using scoped path (crate::module::Trait).

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod animal;
mod dog;

--- file: sample/src/animal.rs ---
pub trait Animal {
    fn speak(&self);
}

--- file: sample/src/dog.rs ---
pub struct Dog {
    pub name: String,
}

impl crate::animal::Animal for Dog {
    fn speak(&self) {
        println!("Woof!");
    }
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 animal)
  (module:3 dog)
)

(root:4 002_animal (002_animal)
  (trait:5 Animal
    (method:6 speak
      (parameter:7 self @type:5 Animal)
    )
  )
)

(root:8 003_dog (003_dog)
  (class:9 Dog
    (field:10 name @type String)
  )
  (impl:11 Dog @type:9 @trait:5
    (method:12 speak
      (parameter:13 self @type:9 Dog)
    )
  )
)

