===============================================================================
trait-impl-cross-file
===============================================================================
Struct in one file implements a trait defined in another file.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod traits;
mod impls;

--- file: sample/src/traits.rs ---
pub trait Render {
    fn render(&self) -> String;
}

--- file: sample/src/impls.rs ---
use crate::traits::Render;

pub struct Html {
    pub content: String,
}

impl Render for Html {
    fn render(&self) -> String {
        format!("<p>{}</p>", self.content)
    }
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 traits)
  (module:3 impls)
)

(root:4 002_traits (002_traits)
  (trait:5 Render
    (method:6 render
      (parameter:7 self @type:5 Render)
      (return:8 @type String)
    )
  )
)

(root:9 003_impls (003_impls)
  (class:10 Html
    (field:11 content @type String)
  )
  (impl:12 Html @type:10 @trait:5
    (method:13 render
      (parameter:14 self @type:10 Html)
      (return:15 @type String)
    )
  )
)

