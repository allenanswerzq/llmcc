===============================================================================
enum-in-function-signatures
===============================================================================
Test enums used in function parameters and return types.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod handlers;

--- file: sample/src/types.rs ---
pub struct User {
    pub id: u64,
}

pub enum Status {
    Active,
    Inactive,
}

pub enum Response {
    Success(User),
    Error(String),
}

--- file: sample/src/handlers.rs ---
use crate::types::{User, Status, Response};

pub fn get_user_status(user: User) -> Status {
    Status::Active
}

pub fn process_status(status: Status) -> Response {
    Response::Success(User { id: 1 })
}

pub fn handle_response(response: Response) -> bool {
    true
}

