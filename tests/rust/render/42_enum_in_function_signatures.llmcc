    (field:6 id @type u64)
  )
  (enum:7 Status
    (field:8 Active)
    (field:9 Inactive)
  )
  (enum:10 Response
    (field:11 Success
      (field:12 0 @type:5 User)
    )
    (field:13 Error
      (field:14 0 @type String)
    )
  )
)

(root:15 003_handlers (003_handlers)
  (func:16 get_user_status
    (parameter:17 user @type:5 User)
    (return:18 @type:7 Status)
    (@tdep:5 User)
    (@tdep:7 Status)
  )
  (func:19 process_status
    (parameter:20 status @type:7 Status)
    (return:21 @type:10 Response)
    (@tdep:5 User)
    (@tdep:7 Status)
    (@tdep:10 Response)
  )
  (func:23 handle_response
    (parameter:24 response @type:10 Response)
    (return:25 @type bool)
    (@tdep:10 Response)
  )
)

