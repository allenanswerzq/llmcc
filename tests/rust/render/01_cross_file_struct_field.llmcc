digraph architecture {

  subgraph cluster_root_0_sample {
    label="sample";

    subgraph cluster_root_0_sample_0_002_types_rs {
      label="002_types.rs";

      n5[label="User", package="sample", file="002_types.rs", path="$TMP/sample/src/002_types.rs:1", kind="struct"];
    }

    subgraph cluster_root_0_sample_1_003_services_rs {
      label="003_services.rs";

      n9[label="UserService", package="sample", file="003_services.rs", path="$TMP/sample/src/003_services.rs:3", kind="struct"];
    }

  }


n5 -> n9 [rel="field", from="field_type", to="container"];
