===============================================================================
pub-use-reexport
===============================================================================
Re-exported type via pub use.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod internal;
pub use internal::Secret;

mod consumer;

--- file: sample/src/internal.rs ---
pub struct Secret {
    pub key: String,
}

--- file: sample/src/consumer.rs ---
use crate::Secret;

pub struct Consumer {
    pub secret: Secret,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 internal)
  (module:3 consumer)
)

(root:4 002_internal (002_internal)
  (class:5 Secret
    (field:6 key @type String)
  )
)

(root:7 003_consumer (003_consumer)
  (class:8 Consumer
    (field:9 secret @type:5 Secret)
    (@tdep:5 Secret)
  )
)

