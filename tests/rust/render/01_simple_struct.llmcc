===============================================================================
simple-struct
===============================================================================
Test that a simple struct appears in the architecture graph.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---

struct Foo;

pub struct User {
    pub name: Foo,
    pub age: i32,
}

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Foo", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:2", kind="struct", shape="box"];
      n3[label="User", package="sample", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.rs:4", kind="struct", shape="box"];
    }

  }


n2 -> n3 [rel="field", from="field_type", to="container"];
}
