===============================================================================
cross-file-multi-import
===============================================================================
Struct imports multiple types from different files.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod user;
mod role;
mod auth;

--- file: sample/src/user.rs ---
pub struct User {
    pub id: u32,
}

--- file: sample/src/role.rs ---
pub struct Role {
    pub level: u32,
}

--- file: sample/src/auth.rs ---
use crate::user::User;
use crate::role::Role;

pub struct Session {
    pub user: User,
    pub role: Role,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 user)
  (module:3 role)
  (module:4 auth)
)

(root:5 002_user (002_user)
  (class:6 User
    (field:7 id @type u32)
  )
)

(root:8 003_role (003_role)
  (class:9 Role
    (field:10 level @type u32)
  )
)

(root:11 004_auth (004_auth)
  (class:12 Session
    (field:13 user @type:6 User)
    (field:14 role @type:9 Role)
    (@tdep:6 User)
    (@tdep:9 Role)
  )
)

