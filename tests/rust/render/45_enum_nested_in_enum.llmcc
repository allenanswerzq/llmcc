===============================================================================
enum-nested-in-enum
===============================================================================
Test enums containing other enums in variants.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod messages;

--- file: sample/src/types.rs ---
pub enum Priority {
    Low,
    Medium,
    High,
}

pub enum Status {
    Pending,
    Active,
    Done,
}

--- file: sample/src/messages.rs ---
use crate::types::{Priority, Status};

pub enum Message {
    Simple(String),
    StatusUpdate {
        status: Status,
        priority: Priority,
    },
    PriorityChange(Priority),
}

pub enum Notification {
    Message(Message),
    Alert {
        priority: Priority,
    },
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 messages)
)

(root:4 002_types (002_types)
  (enum:5 Priority
    (field:6 Low)
    (field:7 Medium)
    (field:8 High)
  )
  (enum:9 Status
    (field:10 Pending)
    (field:11 Active)
    (field:12 Done)
  )
)

(root:13 003_messages (003_messages)
  (enum:14 Message
    (field:15 Simple
      (field:16 0 @type String)
    )
    (field:17 StatusUpdate
      (field:18 status @type:9 Status)
      (field:19 priority @type:5 Priority)
    )
    (field:20 PriorityChange
      (field:21 0 @type:5 Priority)
    )
  )
  (enum:22 Notification
    (field:23 Message
      (field:24 0 @type:14 Message)
    )
    (field:25 Alert
      (field:26 priority @type:5 Priority)
    )
  )
)

