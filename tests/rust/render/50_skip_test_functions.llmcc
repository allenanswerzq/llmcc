===============================================================================
skip-test-functions
===============================================================================
Test functions with #[test] attribute should be excluded from the architecture graph.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
pub struct Config {
    pub name: String,
}

pub fn init(config: Config) {
    println!("{}", config.name);
}

#[test]
fn test_init() {
    let c = Config { name: "test".to_string() };
    init(c);
}

#[cfg(test)]
fn helper_for_tests() {
    // This should be excluded
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (class:2 Config
    (field:3 name @type String)
  )
  (func:4 init
    (parameter:5 config @type:2 Config)
    (@tdep:2 Config)
  )
)

