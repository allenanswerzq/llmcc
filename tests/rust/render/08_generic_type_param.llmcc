===============================================================================
generic-type-param
===============================================================================
Generic struct with type parameter referencing concrete types.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod model;
mod store;

--- file: sample/src/model.rs ---
pub struct Item {
    pub id: u64,
    pub name: String,
}

--- file: sample/src/store.rs ---
use crate::model::Item;

pub struct Cache<T> {
    pub items: Vec<T>,
}

pub fn create_cache() -> Cache<Item> {
    Cache { items: Vec::new() }
}

