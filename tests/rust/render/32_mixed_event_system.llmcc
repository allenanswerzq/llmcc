===============================================================================
mixed-event-system
===============================================================================
Event-driven system with enum variants, trait objects, and callbacks.
Combines: enums, traits, Box<dyn Trait>, cross-file, multiple structs.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod events;
mod handlers;
mod dispatcher;

--- file: sample/src/events.rs ---
pub enum Event {
    Click { x: i32, y: i32 },
    KeyPress { code: u32 },
    Resize { width: u32, height: u32 },
}

pub trait EventHandler {
    fn handle(&self, event: &Event);
}

--- file: sample/src/handlers.rs ---
use crate::events::{Event, EventHandler};

pub struct ClickHandler {
    pub name: String,
}

pub struct KeyHandler {
    pub buffer: String,
}

impl EventHandler for ClickHandler {
    fn handle(&self, event: &Event) {}
}

impl EventHandler for KeyHandler {
    fn handle(&self, event: &Event) {}
}

--- file: sample/src/dispatcher.rs ---
use crate::events::{Event, EventHandler};

pub struct EventDispatcher {
    pub handlers: Vec<Box<dyn EventHandler>>,
}

impl EventDispatcher {
    pub fn dispatch(&self, event: Event) {
        for handler in &self.handlers {
            handler.handle(&event);
        }
    }

    pub fn add_handler(&mut self, handler: Box<dyn EventHandler>) {
        self.handlers.push(handler);
    }
}

