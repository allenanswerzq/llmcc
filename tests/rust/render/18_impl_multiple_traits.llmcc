===============================================================================
impl-multiple-traits
===============================================================================
Struct implements multiple traits.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod traits;
mod entity;

--- file: sample/src/traits.rs ---
pub trait Drawable {
    fn draw(&self);
}

pub trait Clickable {
    fn click(&self);
}

--- file: sample/src/entity.rs ---
use crate::traits::{Drawable, Clickable};

pub struct Button {
    pub label: String,
}

impl Drawable for Button {
    fn draw(&self) {}
}

impl Clickable for Button {
    fn click(&self) {}
}

