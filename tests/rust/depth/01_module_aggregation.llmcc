===============================================================================
module-aggregation
===============================================================================
Test that depth 2 (Module) aggregates nodes into module-level components.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod models;
mod services;

pub use models::User;
pub use services::UserService;

--- file: sample/src/models.rs ---
pub struct User {
    pub id: u64,
    pub name: String,
}

pub struct Profile {
    pub bio: String,
}

--- file: sample/src/services.rs ---
use crate::models::{User, Profile};

pub struct UserService {
    pub user: User,
    pub profile: Profile,
}

pub fn create_user() -> User {
    User { id: 1, name: "Alice".to_string() }
}

--- expect:arch-graph-depth-2 ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  namespace_sample_002_models[label="sample::002_models", kind="module", package="sample", module="002_models", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src"];
  namespace_sample_003_services[label="sample::003_services", kind="module", package="sample", module="003_services", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src"];

namespace_sample_003_services -> namespace_sample_002_models [rel="depends_on", weight="3", via="field:2,return:1"];
}
