===============================================================================
edge-type-arg
===============================================================================
Test that type_arg edges create correct dependency direction.
When generic G<T> uses type argument T, G's crate depends on T's crate.
At crate level: crate_app -> crate_types (app depends on types)

--- file: types/Cargo.toml ---
[package]
name = "types"

--- file: types/src/lib.rs ---
pub struct Item {
    pub value: u32,
}

--- file: app/Cargo.toml ---
[package]
name = "app"

[dependencies]
types = { path = "../types" }

--- file: app/src/lib.rs ---
use types::Item;

/// Container uses Item as type argument in Vec
pub struct Container {
    pub items: Vec<Item>,
}

--- expect:arch-graph-depth-3 ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_app {
    label="app";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_app_0_003_lib_rs {
      label="003_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n5[label="Container", package="app", file="003_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/app/src/003_lib.rs:4", kind="struct", shape="box"];
    }

  }

  subgraph cluster_root_1_types {
    label="types";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_1_types_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Item", package="types", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/types/src/001_lib.rs:1", kind="struct", shape="box"];
    }

  }


n2 -> n5 [rel="nested_field", from="type_dep", to="container"];
}

