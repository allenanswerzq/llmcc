===============================================================================
cross-crate-call-edge
===============================================================================
Function in one crate calls function in another crate.
Edge direction: caller -> callee.

--- file: utils/Cargo.toml ---
[package]
name = "utils"

--- file: utils/src/lib.rs ---
pub fn hash(data: &[u8]) -> u64 {
    data.len() as u64
}

--- file: app/Cargo.toml ---
[package]
name = "app"

[dependencies]
utils = { path = "../utils" }

--- file: app/src/lib.rs ---
use utils::hash;

pub fn process(input: &str) -> u64 {
    hash(input.as_bytes())
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (func:2 hash
    (parameter:3 data @type u8)
    (return:4 @type u64)
  )
)

(root:6 003_lib (003_lib)
  (func:7 process
    (parameter:8 input @type str)
    (return:9 @type u64)
  )
)

