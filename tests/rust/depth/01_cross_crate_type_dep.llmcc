===============================================================================
cross-crate-type-dep
===============================================================================
Type defined in one crate used as field in another crate.
Edge direction: consumer -> provider.

--- file: core/Cargo.toml ---
[package]
name = "core"

--- file: core/src/lib.rs ---
pub struct Config {
    pub debug: bool,
    pub port: u16,
}

--- file: app/Cargo.toml ---
[package]
name = "app"

[dependencies]
core = { path = "../core" }

--- file: app/src/lib.rs ---
use core::Config;

pub struct Server {
    pub config: Config,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (class:2 Config
    (field:3 debug @type bool)
    (field:4 port @type u16)
  )
)

(root:5 003_lib (003_lib)
  (class:6 Server
    (field:7 config @type:2 Config)
    (@tdep:2 Config)
  )
)

--- expect:arch-graph ---
