===============================================================================
edge-no-reverse-dependency
===============================================================================
Test that there are NO reverse edges at crate level.
When app depends on types, there should NOT be types -> app edge.
This guards against false bidirectional edges in crate graphs.

--- file: types/Cargo.toml ---
[package]
name = "types"

--- file: types/src/lib.rs ---
/// Types crate has no dependency on app
pub struct Data {
    pub value: u32,
}

pub trait Handler {
    fn handle(&self, data: &Data);
}

--- file: app/Cargo.toml ---
[package]
name = "app"

[dependencies]
types = { path = "../types" }

--- file: app/src/lib.rs ---
use types::{Data, Handler};

/// App uses types from types crate
pub struct DataProcessor {
    pub data: Data,
}

/// App implements trait from types crate
pub struct MyHandler;

impl Handler for MyHandler {
    fn handle(&self, data: &Data) {
        let _ = data.value;
    }
}

/// App calls function that takes types parameter
pub fn process(data: &Data) -> u32 {
    data.value
}

--- expect:arch-graph-depth-3 ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_app {
    label="app";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_app_0_003_lib_rs {
      label="003_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n9[label="DataProcessor", package="app", file="003_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/app/src/003_lib.rs:4", kind="struct", shape="box"];
      n11[label="MyHandler", package="app", file="003_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/app/src/003_lib.rs:9", kind="struct", shape="box"];
      n16[label="process", package="app", file="003_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/app/src/003_lib.rs:18", kind="function", shape="ellipse"];
    }

  }

  subgraph cluster_root_1_types {
    label="types";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_1_types_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Data", package="types", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/types/src/001_lib.rs:2", kind="struct", shape="box"];
      n4[label="Handler", package="types", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/types/src/001_lib.rs:6", kind="trait", shape="box"];
    }

  }


n2 -> n9 [rel="field", from="field_type", to="container"];
n2 -> n16 [rel="param", from="input", to="func"];
n4 -> n11 [rel="conformance", from="contract", to="conforms"];
}

