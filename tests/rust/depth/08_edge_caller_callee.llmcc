===============================================================================
edge-caller-callee
===============================================================================
Test that caller->callee edges create correct dependency direction.
When function A calls function B, A's crate depends on B's crate.
At crate level: crate_app -> crate_utils (app depends on utils)

--- file: utils/Cargo.toml ---
[package]
name = "utils"

--- file: utils/src/lib.rs ---
pub fn helper() -> u32 {
    42
}

--- file: app/Cargo.toml ---
[package]
name = "app"

[dependencies]
utils = { path = "../utils" }

--- file: app/src/lib.rs ---
use utils::helper;

/// Function calls helper from utils crate
pub fn main_logic() -> u32 {
    helper() + 1
}

--- expect:arch-graph-depth-3 ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_app {
    label="app";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_app_0_003_lib_rs {
      label="003_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n5[label="main_logic", package="app", file="003_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/app/src/003_lib.rs:4", kind="function", shape="ellipse"];
    }

  }

  subgraph cluster_root_1_utils {
    label="utils";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_1_utils_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="helper", package="utils", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/utils/src/001_lib.rs:1", kind="function", shape="ellipse"];
    }

  }


n5 -> n2 [rel="call", from="caller", to="callee"];
}

