digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_app {
    label="app";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_app_0_003_lib_rs {
      label="003_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n8[label="initialize", package="app", file="003_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/app/src/003_lib.rs:4", kind="function", shape="ellipse"];
    }

  }

  subgraph cluster_root_1_types {
    label="types";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_1_types_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Config", package="types", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/types/src/001_lib.rs:1", kind="struct", shape="box"];
    }

  }


n8 -> n2 [rel="type_dep", from="source", to="type_dep"];
}

