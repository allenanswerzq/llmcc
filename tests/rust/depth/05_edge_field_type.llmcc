===============================================================================
edge-field-type
===============================================================================
Test that field_type edges create correct dependency direction.
When struct A has a field of type B, A depends on B.
At crate level: crate_app -> crate_types (app depends on types)

--- file: types/Cargo.toml ---
[package]
name = "types"

--- file: types/src/lib.rs ---
pub struct UserId(pub u64);

pub struct UserName(pub String);

--- file: app/Cargo.toml ---
[package]
name = "app"

[dependencies]
types = { path = "../types" }

--- file: app/src/lib.rs ---
use types::{UserId, UserName};

/// User struct has fields of types from 'types' crate
pub struct User {
    pub id: UserId,
    pub name: UserName,
}

--- expect:arch-graph-depth-3 ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_app {
    label="app";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_app_0_003_lib_rs {
      label="003_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n7[label="User", package="app", file="003_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/app/src/003_lib.rs:4", kind="struct", shape="box"];
    }

  }

  subgraph cluster_root_1_types {
    label="types";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_1_types_0_001_lib_rs {
      label="001_lib.rs";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="UserId", package="types", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/types/src/001_lib.rs:1", kind="struct", shape="box"];
      n4[label="UserName", package="types", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/types/src/001_lib.rs:3", kind="struct", shape="box"];
    }

  }


n2 -> n7 [rel="field", from="field_type", to="container"];
n4 -> n7 [rel="field", from="field_type", to="container"];
}

--- expect:arch-graph-depth-2 ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  namespace_app_003_lib[label="app::003_lib", kind="module", package="app", module="003_lib", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/app/src"];
  namespace_types_001_lib[label="types::001_lib", kind="module", package="types", module="001_lib", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/types/src"];

namespace_app_003_lib -> namespace_types_001_lib [rel="depends_on", weight="2", via="field:2"];
}

