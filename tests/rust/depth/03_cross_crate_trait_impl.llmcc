===============================================================================
cross-crate-trait-impl
===============================================================================
Trait defined in one crate, implemented in another.
Edge direction: implementing crate -> trait crate.

--- file: contracts/Cargo.toml ---
[package]
name = "contracts"

--- file: contracts/src/lib.rs ---
pub trait Storage {
    fn get(&self, key: &str) -> Option<String>;
    fn set(&mut self, key: &str, value: &str);
}

--- file: impl_mem/Cargo.toml ---
[package]
name = "impl_mem"

[dependencies]
contracts = { path = "../contracts" }

--- file: impl_mem/src/lib.rs ---
use contracts::Storage;
use std::collections::HashMap;

pub struct MemStore {
    data: HashMap<String, String>,
}

impl Storage for MemStore {
    fn get(&self, key: &str) -> Option<String> {
        self.data.get(key).cloned()
    }

    fn set(&mut self, key: &str, value: &str) {
        self.data.insert(key.to_string(), value.to_string());
    }
}

