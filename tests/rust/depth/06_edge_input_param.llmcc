===============================================================================
edge-input-param
===============================================================================
Test that input edges create correct dependency direction.
When function F takes parameter of type T, F's crate depends on T's crate.
At crate level: crate_app -> crate_types (app depends on types)

--- file: types/Cargo.toml ---
[package]
name = "types"

--- file: types/src/lib.rs ---
pub struct Request {
    pub data: String,
}

--- file: app/Cargo.toml ---
[package]
name = "app"

[dependencies]
types = { path = "../types" }

--- file: app/src/lib.rs ---
use types::Request;

/// Function takes Request as input parameter
pub fn process_request(req: &Request) {
    // process the request
}

