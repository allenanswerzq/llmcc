      bgcolor="#fafafa";

      n2[label="Request", package="types", file="001_lib.rs", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/types/src/001_lib.rs:1", kind="struct", shape="box"];
    }

