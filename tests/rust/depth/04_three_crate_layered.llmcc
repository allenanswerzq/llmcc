===============================================================================
three-crate-layered
===============================================================================
Three crates in a layered architecture: app -> service -> model.
Verifies transitive dependency edges.

--- file: model/Cargo.toml ---
[package]
name = "model"

--- file: model/src/lib.rs ---
pub struct User {
    pub id: u64,
    pub email: String,
}

--- file: service/Cargo.toml ---
[package]
name = "service"

[dependencies]
model = { path = "../model" }

--- file: service/src/lib.rs ---
use model::User;

pub fn find_user(id: u64) -> User {
    User { id, email: String::new() }
}

--- file: app/Cargo.toml ---
[package]
name = "app"

[dependencies]
service = { path = "../service" }
model = { path = "../model" }

--- file: app/src/lib.rs ---
use model::User;
use service::find_user;

pub fn get_email(id: u64) -> String {
    let user: User = find_user(id);
    user.email
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (class:2 User
    (field:3 id @type u64)
    (field:4 email @type String)
  )
)

(root:5 003_lib (003_lib)
  (func:6 find_user
    (parameter:7 id @type u64)
    (return:8 @type:2 User)
    (@tdep:2 User)
  )
)

(root:10 005_lib (005_lib)
  (func:11 get_email
    (parameter:12 id @type u64)
    (return:13 @type String)
  )
)

