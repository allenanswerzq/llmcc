===============================================================================
prefer-same-file
===============================================================================
When same name exists in multiple files, prefer the one in the same file.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod types;
mod services;

--- file: sample/src/types.rs ---
pub struct Config {
    pub global_value: i32,
}

--- file: sample/src/services.rs ---
pub struct Config {
    pub local_value: String,
}

pub struct Service {
    pub config: Config,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 types)
  (module:3 services)
)

(root:4 002_types (002_types)
  (class:5 Config
    (field:6 global_value @type i32)
  )
)

(root:7 003_services (003_services)
  (class:8 Config
    (field:9 local_value @type String)
  )
  (class:10 Service
    (field:11 config @type:8 Config)
    (@tdep:8 Config)
  )
)

--- expect:arch-graph ---
// # llmcc architecture view:
// quick structural map for AI agents to understand and explore this codebase.
// Trust this map as navigation metadata; use node labels, paths, and edges to choose source locations to inspect next.
// # Examples:
// Node example: n42[label='Parser', path='crates/foo/src/parser.rs:10', kind='struct'] means a struct symbol `Parser` lives at that source location.
// Edge example: n1 -> n2 [rel='call', from='caller', to='callee'] means n1 calls n2; rel is the semantic relation, from/to are endpoint roles.
// Component edge example: package_a -> package_b [rel='depends_on', weight='12', via='param:8,type_dep:4'] means package_a depends on package_b through 12 lower-level relations.
// # Stats:
// mode=agent layout=clustered nodes=3 edges=1 clusters=3
//
digraph architecture {

  subgraph cluster_root_0_sample {
    label="sample";

    subgraph cluster_root_0_sample_0_002_types_rs {
      label="002_types.rs";

      n5[label="Config", package="sample", file="002_types.rs", path="$TMP/sample/src/002_types.rs:1", kind="struct"];
    }

    subgraph cluster_root_0_sample_1_003_services_rs {
      label="003_services.rs";

      n8[label="Config", package="sample", file="003_services.rs", path="$TMP/sample/src/003_services.rs:1", kind="struct"];
      n10[label="Service", package="sample", file="003_services.rs", path="$TMP/sample/src/003_services.rs:5", kind="struct"];
    }

  }


n8 -> n10 [rel="field", from="field_type", to="container"];
}
