  (module:2 custom_terminal)
  (module:3 consumer)
)

(root:4 002_custom_terminal (002_custom_terminal)
  (class:5 Frame
    (field:6 width @type u32)
  )
)

(root:7 003_consumer (003_consumer)
  (func:8 render
    (parameter:9 frame @type:5 Frame)
    (@tdep:5 Frame)
  )
)

(root:10 005_lib (005_lib)
  (module:11 custom_terminal)
  (module:12 consumer)
)

(root:13 006_custom_terminal (006_custom_terminal)
  (class:14 Frame
    (field:15 buffer @type buffer)
  )
)

(root:16 007_consumer (007_consumer)
  (func:17 render
    (parameter:18 frame @type:14 Frame)
    (@tdep:14 Frame)
  )
)

