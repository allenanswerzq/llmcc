===============================================================================
type-alias-resolution
===============================================================================
Test that type aliases resolve correctly when there are same-named types.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod internal;
mod public;

pub use public::Result;

--- file: sample/src/internal.rs ---

pub struct Error {
    pub internal_code: i32,
}

pub type Result<T> = std::result::Result<T, Error>;

--- file: sample/src/public.rs ---

pub struct Error {
    pub user_message: String,
}

// Public Result uses public::Error
pub type Result<T> = std::result::Result<T, Error>;

pub struct Api {
    pub last_error: Error,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 internal)
  (module:3 public)
)

(root:4 002_internal (002_internal)
  (class:5 Error
    (field:6 internal_code @type i32)
  )
  (alias:7 Result)
)

(root:8 003_public (003_public)
  (class:9 Error
    (field:10 user_message @type String)
  )
  (alias:11 Result)
  (class:12 Api
    (field:13 last_error @type:9 Error)
    (@tdep:9 Error)
  )
)

