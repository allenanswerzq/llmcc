===============================================================================
prefer-import-over-global
===============================================================================
Explicit use-import should be preferred over same-name global.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod external;
mod consumer;

pub struct Error {
    pub code: i32,
}

--- file: sample/src/external.rs ---
pub struct Error {
    pub message: String,
}

--- file: sample/src/consumer.rs ---
use crate::external::Error;

pub fn fail() -> Error {
    Error { message: "oops".into() }
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 external)
  (module:3 consumer)
  (class:4 Error
    (field:5 code @type i32)
  )
)

(root:6 002_external (002_external)
  (class:7 Error
    (field:8 message @type String)
  )
)

(root:9 003_consumer (003_consumer)
  (func:10 fail
    (return:11 @type:7 Error)
    (@tdep:7 Error)
  )
)

