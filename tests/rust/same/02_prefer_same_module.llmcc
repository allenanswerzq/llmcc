===============================================================================
prefer-same-module
===============================================================================
Test that symbol resolution prefers types defined in the same module
over types with the same name in other modules.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod data;
mod services;

--- file: sample/src/data/mod.rs ---
mod models;
mod helpers;
pub use models::*;
pub use helpers::*;

--- file: sample/src/data/models.rs ---

// Entity defined in data module
pub struct Entity {
    pub id: u64,
}

--- file: sample/src/data/helpers.rs ---

use super::Entity;

// Helper in same module uses Entity from same module
pub struct EntityWrapper {
    pub inner: Entity,
}

--- file: sample/src/services/mod.rs ---
mod handlers;
pub use handlers::*;

--- file: sample/src/services/handlers.rs ---

// Different Entity in services module
pub struct Entity {
    pub name: String,
}

pub struct Handler {
    // Should resolve to local Entity (services module), not data::Entity
    pub entity: Entity,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 data)
  (module:3 services)
)

(root:4 002_mod (002_mod)
  (module:5 models)
  (module:6 helpers)
)

(root:7 003_models (003_models)
  (class:8 Entity
    (field:9 id @type u64)
  )
)

(root:10 004_helpers (004_helpers)
  (class:11 EntityWrapper
    (field:12 inner @type:16 Entity)
    (@tdep:16 Entity)
  )
)

(root:13 005_mod (005_mod)
  (module:14 handlers)
)

(root:15 006_handlers (006_handlers)
  (class:16 Entity
    (field:17 name @type String)
  )
  (class:18 Handler
    (field:19 entity @type:16 Entity)
    (@tdep:16 Entity)
  )
)

