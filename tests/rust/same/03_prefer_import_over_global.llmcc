===============================================================================
prefer-import-over-global
===============================================================================
Test that explicitly imported types are preferred over same-named types
that might be available through other means.

--- file: sample/Cargo.toml ---
[package]
name = "sample"

--- file: sample/src/lib.rs ---
mod v1;
mod v2;
mod consumer;

--- file: sample/src/v1.rs ---

pub struct Response {
    pub data: String,
    pub version: u32,
}

--- file: sample/src/v2.rs ---

pub struct Response {
    pub payload: Vec<u8>,
    pub status: i32,
}

--- file: sample/src/consumer.rs ---

// Explicitly import v2::Response
use crate::v2::Response;

pub struct Client {
    // Should resolve to v2::Response due to explicit import
    pub last_response: Response,
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (module:2 v1)
  (module:3 v2)
  (module:4 consumer)
)

(root:5 002_v1 (002_v1)
  (class:6 Response
    (field:7 data @type String)
    (field:8 version @type u32)
  )
)

(root:9 003_v2 (003_v2)
  (class:10 Response
    (field:11 payload @type payload)
    (field:12 status @type i32)
  )
)

(root:13 004_consumer (004_consumer)
  (class:14 Client
    (field:15 last_response @type:10 Response)
    (@tdep:10 Response)
  )
)

