===============================================================================
method-chain-field-resolution
===============================================================================
Method call return-type propagation for chained field access.
lang: cpp

--- file: src/lib.cpp ---
struct Meta {
    int code;
};

struct Service {
    Meta get_meta() { return Meta{}; }
};

int read_code(Service svc) {
    return svc.get_meta().code;
}

--- expect:block-graph ---
(root:1 lib ($TMP/src/lib.cpp)
  (class:2 Meta
    (field:3 int @type int)
  )
  (class:4 Service
    (method:5 get_meta)
  )
  (func:6 read_code
    (parameter:7 svc @type:4 Service)
  )
)

