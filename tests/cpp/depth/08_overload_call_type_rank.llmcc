===============================================================================
overload-call-type-rank
===============================================================================
Test that same-arity C++ overload calls prefer exact primitive argument types.
lang: c++

--- file: sample/CMakeLists.txt ---
cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/lib.cpp ---
int convert(int value) { return value; }
double convert(double value) { return value; }

void run() {
    convert(1);
    convert(1.5);
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (func:2 convert
    (parameter:3 value @type int)
  )
  (func:4 convert
    (parameter:5 value @type double)
  )
  (func:6 run
    (@fdep:2 convert)
    (@fdep:4 convert)
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_cpp {
      label="001_lib.cpp";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="convert", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:1", kind="function", shape="ellipse"];
      n4[label="convert", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:2", kind="function", shape="ellipse"];
      n6[label="run", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:4", kind="function", shape="ellipse"];
    }

  }


n6 -> n2 [rel="call", from="caller", to="callee"];
n6 -> n4 [rel="call", from="caller", to="callee"];
}
