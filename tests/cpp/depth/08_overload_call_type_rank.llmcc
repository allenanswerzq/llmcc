===============================================================================
overload-call-type-rank
===============================================================================
Test that same-arity C++ overload calls prefer exact primitive argument types.
lang: c++

--- file: sample/CMakeLists.txt ---
cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/lib.cpp ---
int convert(int value) { return value; }
double convert(double value) { return value; }

void run() {
    convert(1);
    convert(1.5);
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (func:2 convert
    (parameter:3 value @type int)
  )
  (func:4 convert
    (parameter:5 value @type double)
  )
  (func:6 run
    (@fdep:2 convert)
    (@fdep:4 convert)
  )
)

--- expect:arch-graph ---
// # llmcc architecture view:
// quick structural map for AI agents to understand and explore this codebase.
// Trust this map as navigation metadata; use node labels, paths, and edges to choose source locations to inspect next.
// # Examples:
// Node example: n42[label='Parser', path='crates/foo/src/parser.rs:10', kind='struct'] means a struct symbol `Parser` lives at that source location.
// Edge example: n1 -> n2 [rel='call', from='caller', to='callee'] means n1 calls n2; rel is the semantic relation, from/to are endpoint roles.
// Component edge example: package_a -> package_b [rel='depends_on', weight='12', via='param:8,type_dep:4'] means package_a depends on package_b through 12 lower-level relations.
// # Stats:
// mode=agent layout=clustered nodes=3 edges=2 clusters=2
//
digraph architecture {

  subgraph cluster_root_0_sample {
    label="sample";

    subgraph cluster_root_0_sample_0_001_lib_cpp {
      label="001_lib.cpp";

      n2[label="convert", package="sample", file="001_lib.cpp", path="$TMP/sample/src/001_lib.cpp:1", kind="function"];
      n4[label="convert", package="sample", file="001_lib.cpp", path="$TMP/sample/src/001_lib.cpp:2", kind="function"];
      n6[label="run", package="sample", file="001_lib.cpp", path="$TMP/sample/src/001_lib.cpp:4", kind="function"];
    }

  }


n6 -> n2 [rel="call", from="caller", to="callee"];
n6 -> n4 [rel="call", from="caller", to="callee"];
}
