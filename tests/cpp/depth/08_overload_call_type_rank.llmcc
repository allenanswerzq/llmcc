===============================================================================
overload-call-type-rank
===============================================================================
Test that same-arity C++ overload calls prefer exact primitive argument types.
lang: cpp

--- file: sample/CMakeLists.txt ---
cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/lib.cpp ---
int convert(int value) { return value; }
double convert(double value) { return value; }

void run() {
    convert(1);
    convert(1.5);
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (func:2 convert
    (parameter:3 value @type int)
  )
  (func:4 convert
    (parameter:5 value @type double)
  )
  (func:6 run
    (@fdep:2 convert)
    (@fdep:4 convert)
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  ranksep=0.6;
  nodesep=0.3;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_001_lib_cpp {
    label="001_lib.cpp";
    style=rounded;
        bgcolor="#fafafa";

    n2[label="convert", path="C:\\Users\\ZHANGQ~1\\AppData\\Local\\Temp\\$TMP\\sample\\src\\001_lib.cpp:1", sym_ty="Function", shape=ellipse];
    n4[label="convert", path="C:\\Users\\ZHANGQ~1\\AppData\\Local\\Temp\\$TMP\\sample\\src\\001_lib.cpp:2", sym_ty="Function", shape=ellipse];
    n6[label="run", path="C:\\Users\\ZHANGQ~1\\AppData\\Local\\Temp\\$TMP\\sample\\src\\001_lib.cpp:4", sym_ty="Function", shape=ellipse];
  }


  n6 -> n2 [from="caller", to="callee"];
  n6 -> n4 [from="caller", to="callee"];
}
