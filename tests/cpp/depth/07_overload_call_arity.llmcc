===============================================================================
overload-call-arity
===============================================================================
Test that overloaded C++ free-function calls prefer candidates with matching arity.
lang: cpp

--- file: sample/CMakeLists.txt ---
cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/lib.cpp ---
int add(int a) { return a; }
int add(int a, int b) { return a + b; }

void run() {
    add(1);
    add(1, 2);
}

--- expect:block-graph ---
(root:1 001_lib (001_lib)
  (func:2 add
    (parameter:3 a @type int)
  )
  (func:4 add
    (parameter:5 a @type int)
    (parameter:6 b @type int)
  )
  (func:7 run
    (@fdep:2 add)
    (@fdep:4 add)
  )
)

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  ranksep=0.6;
  nodesep=0.3;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_001_lib_cpp {
    label="001_lib.cpp";
    style=rounded;
        bgcolor="#fafafa";

    n2[label="add", path="C:\\Users\\ZHANGQ~1\\AppData\\Local\\Temp\\$TMP\\sample\\src\\001_lib.cpp:1", sym_ty="Function", shape=ellipse];
    n4[label="add", path="C:\\Users\\ZHANGQ~1\\AppData\\Local\\Temp\\$TMP\\sample\\src\\001_lib.cpp:2", sym_ty="Function", shape=ellipse];
    n7[label="run", path="C:\\Users\\ZHANGQ~1\\AppData\\Local\\Temp\\$TMP\\sample\\src\\001_lib.cpp:4", sym_ty="Function", shape=ellipse];
  }


  n7 -> n2 [from="caller", to="callee"];
  n7 -> n4 [from="caller", to="callee"];
}
