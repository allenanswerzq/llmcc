===============================================================================
edge-extends
===============================================================================
Test that inheritance edges are correctly generated.
lang: c++

--- file: sample/CMakeLists.txt ---
cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/lib.cpp ---
class Base {
public:
    virtual void method() = 0;
};

class Derived : public Base {
public:
    void method() override {}
};

class MoreDerived : public Derived {
public:
    void method() override {}
};

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_cpp {
      label="001_lib.cpp";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Base", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:1", kind="struct", shape="box"];
      n4[label="Derived", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:6", kind="struct", shape="box"];
      n6[label="MoreDerived", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:11", kind="struct", shape="box"];
    }

  }


