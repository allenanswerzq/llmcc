Test package and module hierarchy at depth 2.
lang: cpp

--- file: sample/CMakeLists.txt ---
cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/models/user.cpp ---
namespace models {
    struct User {
        int id;
        std::string name;
    };
}

--- file: sample/src/models/profile.cpp ---
namespace models {
    struct Profile {
        std::string bio;
    };
}

--- file: sample/src/services/user_service.cpp ---
#include "../models/user.cpp"
#include "../models/profile.cpp"

namespace services {
    struct UserService {
        models::User user;
        models::Profile profile;
    };
}

