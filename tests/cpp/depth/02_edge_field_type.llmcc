===============================================================================
edge-field-type
===============================================================================
Test that field type edges are correctly generated.
lang: c++

--- file: sample/CMakeLists.txt ---
cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/lib.cpp ---
struct Address {
    std::string street;
    std::string city;
};

struct Person {
    std::string name;
    Address address;
};

struct Company {
    std::string name;
    Person ceo;
    Address headquarters;
};

--- expect:arch-graph ---
digraph architecture {
  rankdir=TB;
  splines=ortho;
  compound=true;

  node [shape=box, style=rounded];
  edge [arrowsize=0.7];

  subgraph cluster_root_0_sample {
    label="sample";
    style=rounded;
    bgcolor="#f8f8f8";

    subgraph cluster_root_0_sample_0_001_lib_cpp {
      label="001_lib.cpp";
      style=rounded;
      bgcolor="#fafafa";

      n2[label="Address", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:1", kind="struct", shape="box"];
      n5[label="Person", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:6", kind="struct", shape="box"];
      n8[label="Company", package="sample", file="001_lib.cpp", path="C:/Users/ZHANGQ~1/AppData/Local/Temp/$TMP/sample/src/001_lib.cpp:11", kind="struct", shape="box"];
    }

  }


n2 -> n5 [rel="field", from="field_type", to="container"];
n2 -> n8 [rel="field", from="field_type", to="container"];
