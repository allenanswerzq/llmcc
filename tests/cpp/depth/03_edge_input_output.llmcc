cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/lib.cpp ---
struct Input {};
struct Output {};
struct Config {};

Output process(Input input, Config config) {
    return Output{};
}

Input create_input() {
    return Input{};
}

