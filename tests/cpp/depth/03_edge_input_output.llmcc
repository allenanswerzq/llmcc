    subgraph cluster_root_0_sample_0_001_lib_cpp {
      label="001_lib.cpp";

      n2[label="Input", package="sample", file="001_lib.cpp", path="$TMP/sample/src/001_lib.cpp:1", kind="struct"];
      n3[label="Output", package="sample", file="001_lib.cpp", path="$TMP/sample/src/001_lib.cpp:2", kind="struct"];
      n4[label="Config", package="sample", file="001_lib.cpp", path="$TMP/sample/src/001_lib.cpp:3", kind="struct"];
      n5[label="process", package="sample", file="001_lib.cpp", path="$TMP/sample/src/001_lib.cpp:5", kind="function"];
      n8[label="create_input", package="sample", file="001_lib.cpp", path="$TMP/sample/src/001_lib.cpp:9", kind="function"];
    }

  }


n2 -> n5 [rel="param", from="input", to="func"];
n4 -> n5 [rel="param", from="input", to="func"];
