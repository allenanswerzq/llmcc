===============================================================================
alias-qualified-dependencies
===============================================================================
Test that C++ type aliases preserve qualified type dependencies.
lang: cpp

--- file: sample/CMakeLists.txt ---
cmake_minimum_required(VERSION 3.10)
project(sample)

--- file: sample/src/models/user.cpp ---
namespace models {
    struct User {
        int id;
    };

    struct Profile {
        int id;
    };
}

--- file: sample/src/services/user_service.cpp ---
#include "../models/user.cpp"

namespace services {
    using UserAlias = models::User;
    typedef models::Profile ProfileAlias;

    struct UserService {
        UserAlias user;
        ProfileAlias profile;
    };
}

--- expect:block-graph ---
(root:1 001_user (001_user)
  (module:2 models (inline)
    (class:3 User
      (field:4 int @type int)
    )
    (class:5 Profile
      (field:6 int @type int)
    )
  )
)

(root:7 002_user_service (002_user_service)
  (module:8 services (inline)
    (alias:9 UserAlias)
    (alias:10 ProfileAlias)
    (class:11 UserService
      (field:12 UserAlias @type:3 User)
      (field:13 ProfileAlias @type:5 Profile)
    )
  )
)

--- expect:arch-graph-depth-2 ---
digraph architecture {
  rankdir=TB;
  ranksep=0.8;
  nodesep=0.4;
  splines=ortho;
  concentrate=true;

  node [shape=box, style="rounded,filled", fillcolor="#f0f0f0", fontname="Helvetica"];
  edge [color="#888888", arrowsize=0.7];

  labelloc=t;
  fontsize=16;

  namespace_unknown_models[label="unknown::models", path="$TMP\sample\src\models"];
  namespace_unknown_services[label="unknown::services", path="$TMP\sample\src\services"];

  namespace_unknown_services -> namespace_unknown_models;
}
