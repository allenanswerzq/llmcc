===============================================================================
module-layout
===============================================================================
JavaScript project split into domain and service modules.
lang: javascript

--- file: package.json ---
{"name":"sample","type":"module"}

--- file: src/domain/user.js ---
export class User {
    constructor(name) {
        this.name = name;
    }
}

--- file: src/service/user_service.js ---
export class UserService {
    normalize(name) {
        return name.trim();
    }
}

--- expect:arch-graph ---
