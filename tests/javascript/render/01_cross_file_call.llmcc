===============================================================================
cross-file-call
===============================================================================
Function in one JavaScript file calls a function defined in another file.
lang: javascript

--- file: package.json ---
{"name":"sample","type":"module"}

--- file: src/utils.js ---
export function compute(value) {
    return value * 2;
}

--- file: src/app.js ---
import { compute } from "./utils.js";

export function run() {
    return compute(21);
}

