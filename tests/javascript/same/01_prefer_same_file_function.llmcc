===============================================================================
prefer-same-file-function
===============================================================================
When two functions share a name, call resolution should prefer the same file.
lang: javascript

--- file: package.json ---
{"name":"sample","type":"module"}

--- file: src/global.js ---
export function validate() {
    return false;
}

--- file: src/service.js ---
export function validate() {
    return true;
}

export function run() {
    return validate();
}

--- expect:arch-graph ---
