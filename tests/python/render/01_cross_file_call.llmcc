    subgraph cluster_root_0_TMP_1_002_app_py {
      label="002_app.py";

      n4[label="run", package="$TMP", file="002_app.py", path="$TMP/002_app.py:3", kind="function"];
    }

  }


n4 -> n2 [rel="call", from="caller", to="callee"];
